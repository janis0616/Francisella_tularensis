#Tree-building with Harvest Suite and Nextstrain
#Harvest Suite: Parsnp performs microbial core genome alignmentand SNP detection; Harvest-tools converts the Parsnp output (.xmfa) to a format Augur can accept (.vcf)
#Nextstrain: Augur is the bioinformatics pipeline that builds the tree; Auspice is the interactive web-based visualizer

#Docker images required: Parsnp, Harvest-tools, Nextstrain
#Files required: reference sequence (.fasta), consensus sequences (.fasta) in their own directory, metadata (.tsv), auspice-config-custom-data.json (custom settings for tree)
##Do not include the reference genome in the fasta directory 
##Metadata tsv should have the following column headers: strain, subspecies, country, date, source, type
##Dates must be in the format YYYY-MM-DD with unknown fields as X's, i.e. 2013-05-XX, 195X-XX-XX, or XXXX-XX-XX
##The items in the strain column must match the names of the fasta files (this is basically the sample name)
##These strain names cannot contain any spaces or special characters such as ()[]{}|#><


#Parameters
reference_fasta="$1"
samples_fasta_directory="$2"
samples_metadata="$3"
output_directory="$4"

#Parsnp for alignment
parsnp -d $samples_fasta_directory -r $reference_fasta -o $output_directory

#HarvestTools for file conversion
harvesttools -x $output_directory/parsnp.xmfa -V $output_directory/alignment.vcf -f $reference_fasta

#Augur for tree-building
nextstrain shell .
augur tree --alignment $output_directory/alignment.vcf --output $output_directory/tree_raw.nwk --vcf-reference $reference_fasta
augur refine --tree $output_directory/tree_raw.nwk --alignment $output_directory/alignment.vcf --metadata $samples_metadata --output-tree $output_directory/tree.nwk --output-node-data $output_directory/branch_lengths.json --vcf-reference $reference_fasta --timetree --coalescent opt --stochastic-resolve 
augur export v2 --tree $output_directory/tree.nwk --metadata $samples_metadata --node-data $output_directory/branch_lengths.json --output $output_directory/final_tree.json --auspice-config auspice-config-custom-data.json
exit

#View tree
auspice view -datasetDir $output_directory

